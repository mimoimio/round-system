local ReplicatedStorage = game:GetService("ReplicatedStorage")
local PlayerSessions = require(ReplicatedStorage.Shared.producers.PlayerSessions)

local SoundController = {}

-- Sound pool configuration
local POOL_SIZE = 5 -- Pre-create 5 instances of each sound
local soundPools = {} -- {SoundName = {available = {Sound}, inUse = {Sound}}}

-- Volume state
local _sfxVolume = 0.3 -- 0..1
local _listeners: { (state: any) -> () } = {}

local function _getState()
	return {
		volume = _sfxVolume,
	}
end

local function _notify()
	local state = _getState()
	for _, fn in ipairs(_listeners) do
		fn(state)
	end
end

function SoundController.setVolume(v: number)
	_sfxVolume = math.clamp(v, 0, 1)
	_notify()
end

function SoundController.getState()
	return _getState()
end

function SoundController.subscribe(fn: (state: any) -> ()): () -> ()
	table.insert(_listeners, fn)
	fn(_getState())
	return function()
		local idx = table.find(_listeners, fn)
		if idx then
			table.remove(_listeners, idx)
		end
	end
end

-- Initialize a sound pool for a specific sound
local function initializeSoundPool(soundName: string, poolSize: number)
	local sourceSound = game.ReplicatedStorage.Shared.SFX:FindFirstChild(soundName)
	if not sourceSound then
		warn("Sound not found:", soundName)
		return
	end

	soundPools[soundName] = {
		available = {},
		inUse = {},
		source = sourceSound,
	}

	-- Pre-create and load sounds
	for i = 1, poolSize do
		local sound = sourceSound:Clone()
		sound.Parent = game.ReplicatedStorage -- Store in ReplicatedStorage until needed
		if not sound.IsLoaded then
			sound.Loaded:Wait()
		end
		table.insert(soundPools[soundName].available, sound)
	end
end

-- Get a sound from the pool (or create new if pool is empty)
local function getSound(soundName: string): Sound?
	local pool = soundPools[soundName]
	if not pool then
		-- warn("Sound pool not initialized:", soundName)
		initializeSoundPool(soundName, POOL_SIZE)
		pool = soundPools[soundName]

		if not pool then
			return
		end
	end

	local sound
	if #pool.available > 0 then
		-- Reuse from pool
		sound = table.remove(pool.available)
	else
		-- Pool exhausted, create new instance
		sound = pool.source:Clone()
		sound.Parent = game.ReplicatedStorage
		if not sound.IsLoaded then
			sound.Loaded:Wait()
		end
	end

	table.insert(pool.inUse, sound)
	return sound
end

-- Return a sound to the pool
local function returnSound(soundName: string, sound: Sound)
	local pool = soundPools[soundName]
	if not pool then
		sound:Destroy()
		return
	end

	-- Remove from inUse
	local index = table.find(pool.inUse, sound)
	if index then
		table.remove(pool.inUse, index)
	end

	-- Reset sound properties and return to available pool
	sound:Stop()
	sound.Parent = game.ReplicatedStorage
	table.insert(pool.available, sound)
end

local function applyVolume(sound: Sound, poolName: string)
	local pool = soundPools[poolName]
	local base = pool and pool.source and (pool.source.Volume ~= 0 and pool.source.Volume or 1) or 1
	sound.Volume = math.clamp(base * _sfxVolume, 0, 10)
end

function SoundController.CashSound()
	task.spawn(function()
		local sound = getSound("Cash")
		if not sound then
			return
		end

		applyVolume(sound, "Cash")
		sound.Parent = game.Players.LocalPlayer.Character.Head
		sound:Play()
		sound.Ended:Wait()

		-- Return to pool
		returnSound("Cash", sound)
	end)
end
function SoundController.Sound(name: string)
	if not game.Players.LocalPlayer then -- not in story plugin, only when played
		return
	end
	task.spawn(function()
		local sound = getSound(name)
		if not sound then
			print("failed to get sound")
			return
		end

		applyVolume(sound, name)
		sound.Parent = game.Players.LocalPlayer.Character.Head
		sound:Play()
		sound.Ended:Wait()

		-- Return to pool
		returnSound(name, sound)
	end)
end

function SoundController.initialize()
	-- Initialize sound pools for all sounds you want to pool
	task.spawn(function()
		initializeSoundPool("Angry", POOL_SIZE)
		initializeSoundPool("Bubbles", POOL_SIZE)
		initializeSoundPool("Cash", POOL_SIZE)
		initializeSoundPool("Click", POOL_SIZE)
		initializeSoundPool("Cup", POOL_SIZE)
		initializeSoundPool("Done", POOL_SIZE)
		initializeSoundPool("Ices", POOL_SIZE)
		initializeSoundPool("Plap", POOL_SIZE)
		initializeSoundPool("Plink", POOL_SIZE)
		initializeSoundPool("Pour", POOL_SIZE)
		initializeSoundPool("Powder", POOL_SIZE)
		initializeSoundPool("TaDa", POOL_SIZE)
		initializeSoundPool("Talk", POOL_SIZE)
		initializeSoundPool("Trash", POOL_SIZE)
		initializeSoundPool("Wrong", POOL_SIZE)
		initializeSoundPool("Yeah", POOL_SIZE)
	end)
	-- Add more sounds here as needed:

	-- Read SFXVolume from player data once it's available
	local playerId = tostring(game.Players.LocalPlayer.UserId)
	PlayerSessions:once(function(state)
		local player = state.players[playerId]
		local Data = player and player.Data
		return Data and Data.SFXVolume
	end, function(SFXVolume)
		return type(SFXVolume) == "number"
	end, function(state)
		SoundController.setVolume(state)
	end)

	-- game.ReplicatedStorage.Shared.Events:WaitForChild("Wrong").OnClientEvent:Connect(function()
	-- 	SoundController.Sound("Wrong")
	-- end)
	-- game.ReplicatedStorage.Shared.Events:WaitForChild("Angry").OnClientEvent:Connect(function()
	-- 	SoundController.Sound("Angry")
	-- end)
	-- game.ReplicatedStorage.Shared.Events:WaitForChild("Correct").OnClientEvent:Connect(function()
	-- 	SoundController.Sound("Yeah")
	-- end)
end

return SoundController
